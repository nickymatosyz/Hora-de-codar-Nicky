programa
{
	
	funcao inicio()
	{
		
		escreva ("calculador de áreas planas \n")
		escreva ("Paralelograma - A = base . altura  \n")

		real base
		escreva ("base: ")
		leia (base)



		real altura
		escreva ("altura: ")
		leia (altura)

		

		real resultado = base * altura

		escreva ("A área do seu paralelograma é " + resultado)
		
		
	}
}