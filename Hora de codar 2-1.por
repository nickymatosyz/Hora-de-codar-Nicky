programa
{
	
	funcao inicio()
	{
	
		inteiro numero_1, numero_2
		escreva("digite um número: ")
		leia (numero_1)

		escreva ("digite um numero diferente: ")
		leia (numero_2)

		se (numero_1 > numero_2) {
			
			escreva ("O maior número é: " + numero_1)
			
			}


		senao {
			escreva ("O maior número é: " + numero_2)
			} 
	}
}
