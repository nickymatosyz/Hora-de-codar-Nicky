programa
{
	
	funcao inicio()
	{
		real lado_maior
		escreva ("calculador de áreas planas \n")
		escreva ("losango - lado maior . lado menor/2 \n")
		
		escreva ("lado maior: ")
		leia (lado_maior)

		real lado_menor

		escreva ("lado menor")
		leia (lado_menor)

		real resultado = lado_maior * lado_menor

		escreva ("A área do seu losango é " + resultado)
		
		
	}
}