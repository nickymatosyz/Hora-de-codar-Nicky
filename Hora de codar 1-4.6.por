programa
{
	
	funcao inicio()
	{
		
		escreva ("calculador de áreas planas \n")
		escreva ("Triângulo - A = base . altura/2  \n")

		real base
		escreva ("base: ")
		leia (base)



		real altura
		escreva ("altura: ")
		leia (altura)

		

		real resultado = base * altura/2

		escreva ("A área do seu triângulo é " + resultado)
		
		
	}
}