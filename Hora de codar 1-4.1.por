programa
{
	
	funcao inicio()
	{
		real base , altura
		escreva ("calculador de áreas planas \n")
		escreva ("retângulo - A = base . altura\n")
		
		escreva ("base: ")
		leia (base)
		
		escreva ("altura: ")
		leia (altura)

		real resultado = base * altura

		escreva ("A área do seu retângulo é " + resultado)
		
		
	}
}